{% extends "base.html.j2" %}

{% set page = pages.about %}

{% block title %}{{ page.frontmatter.title }}{% endblock %}

{% block content %}
  <section class="page-header">
    <div class="page-header-inner">
      <h1>{{ page.frontmatter.title }}</h1>
      {% if page.frontmatter.intro %}
        <p class="page-intro">{{ page.frontmatter.intro }}</p>
      {% endif %}
    </div>
  </section>

  <section class="prose-section">
    <div class="prose-inner">
      {{ page.body_html | safe }}
    </div>
  </section>

  {% if page.frontmatter.qualifications %}
    <section class="prose-section alt">
      <div class="prose-inner">
        <h2>Qualifications &amp; memberships</h2>
        <ul class="qualifications-list">
          {% for q in page.frontmatter.qualifications %}
            <li>{{ q }}</li>
          {% endfor %}
        </ul>
      </div>
    </section>
  {% endif %}

  <section class="contact-section">
    <div class="section-inner contact-inner">
      <div class="contact-text">
        <h2>Get in touch</h2>
        <p>
          <strong>Phone:</strong>
          <a href="tel:+447853431363">{{ site.phone }}</a>
        </p>
        <p>
          <strong>Email:</strong>
          <a href="mailto:{{ site.email }}">{{ site.email }}</a>
        </p>
      </div>
    </div>
  </section>
{% endblock %}
